global:
  scrape_interval: 15s
  evaluation_interval: 15s
  scrape_timeout: 10s
  external_labels:
    region: {{ prometheus_region }}
    replica: {{ prometheus_role }}

rule_files:
  - "/etc/prometheus/rules/tradeflow.yml"
  - "/etc/prometheus/rules/miscellaneous.yml"
  - "/etc/prometheus/rules/elasticsearch_exporter.yml"
  - "/etc/prometheus/rules/cme_party_registration.yml"

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["{{ ansible_hostname }}:9090"]

  - job_name: last-user-monitoring-devices
    metrics_path: /metrics
    scrape_interval: 600s
    scrape_timeout: 15s
    http_sd_configs:
      - url: http://netbox/api/dcim/devices/?export=prometheus-last-user-devices-eu
        refresh_interval: 600s
        authorization:
          type: "Token"
          credentials: "{{ netbox_api_token }}"   

  - job_name: last-user-monitoring-vm
    metrics_path: /metrics
    scrape_interval: 600s
    scrape_timeout: 15s
    http_sd_configs:
      - url: http://netbox/api/virtualization/virtual-machines/?export=prometheus-last-user-vm-eu
        refresh_interval: 600s
        authorization:
          type: "Token"
          credentials: "{{ netbox_api_token }}"

  - job_name: home-usage-monitoring-devices
